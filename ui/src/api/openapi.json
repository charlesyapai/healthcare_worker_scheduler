  "info": {
    "title": "Healthcare Roster Scheduler v2",
    "version": "2.0.0-phase1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/diagnose": {
      "post": {
        "description": "Millisecond necessary-condition checks (L1).",
        "operationId": "diagnose_api_diagnose_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/FeasibilityIssueOut"
                  },
                  "title": "Response Diagnose Api Diagnose Post",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Diagnose",
        "tags": [
          "diagnostics"
        ]
      }
    },
    "/api/explain": {
      "post": {
        "description": "Soft-relax diagnostic (L3). ~30 s \u2014 use only after an INFEASIBLE solve.",
        "operationId": "explain_api_explain_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExplainReport"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Explain",
        "tags": [
          "diagnostics"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/api/overrides/fill-from-snapshot": {
      "post": {
        "description": "Copy assignments from a completed solve into the overrides list.\n\n`snapshot_id` is \"final\" for the last result, or the 0-based index\n(as a string) of an intermediate event from the same solve.",
        "operationId": "fill_from_snapshot_api_overrides_fill_from_snapshot_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FillFromSnapshotRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/OverrideEntry"
                  },
                  "title": "Response Fill From Snapshot Api Overrides Fill From Snapshot Post",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Fill From Snapshot",
        "tags": [
          "solve"
        ]
      }
    },
    "/api/solve/run": {
      "post": {
        "description": "Blocking REST solve. Used as a fallback when the /api/solve WebSocket\ncan't stay open through a proxy (HF Spaces sometimes drops WS mid-solve\nwith code 1006). No intermediate events \u2014 just the final result.\n\nFastAPI runs sync routes on a thread pool, so the CP-SAT work here\ndoesn't block other requests.",
        "operationId": "solve_sync_api_solve_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RestSolveRequest",
                "default": {
                  "snapshot_assignments": false
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolveResultPayload"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Solve Sync",
